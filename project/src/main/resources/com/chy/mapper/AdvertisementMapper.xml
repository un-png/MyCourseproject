<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.chy.mapper.AdvertisementMapper">
    <insert id="add">
        INSERT INTO advertisement (
                                   title,
                                   position,
                                   type,
                                   media_url,
                                   link,
                                   start_time,
                                   end_time,
                                   target_user,
                                   status,
                                   create_at)
        VALUES
        (#{title},#{position},#{type},#{mediaUrl},#{link},#{startTime},#{endTime},#{targetUser},#{status},#{createAt});
    </insert>
    <select id="advertisementList" resultType="com.chy.pojo.Advertisement">
        select
            id as advertisementId,
            title,
            position,
            type,
            media_url as mediaUrl,
            link,
            start_time as startTime,
            end_time as endTime,
            target_user as targetUser,
            status,
            click_count as clickCount,
            create_at as createAt
        from advertisement
        <where>
            <if test="title != null and title != ''">
                and title like concat('%', #{title}, '%')
            </if>
            <if test="position != null and position != ''">
                and position = #{position}
            </if>
            <if test="type != null and type != ''">
                and type = #{type}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
    </select>
    <update id="advertisementEdit">
        update advertisement
        <set>
            <if test="title != null and title != ''">
                title = #{title},
            </if>
            <if test="position != null and position != ''">
                position = #{position},
            </if>
            <if test="type != null and type != ''">
                type = #{type},
            </if>
            <if test="mediaUrl != null and mediaUrl != ''">
                media_url = #{mediaUrl},
            </if>
            <if test="link != null and link != ''">
                link = #{link},
            </if>
            <if test="startTime != null">
                start_time = #{startTime},
            </if>
            <if test="endTime != null">
                end_time = #{endTime},
            </if>
            <if test="targetUser != null and targetUser != ''">
                target_user = #{targetUser},
            </if>
            <if test="status != null and status != ''">
                status = #{status},
            </if>
            <if test="clickCount != null">
                click_count = #{clickCount},
            </if>
        </set>
        where id = #{advertisementId}
    </update>
</mapper>
